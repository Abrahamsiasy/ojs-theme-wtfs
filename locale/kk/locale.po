msgstr "Noto Serif: Google сандық шрифтінің серифтік нұсқасы."

msgid "plugins.themes.custom.option.typography.notoSerif_notoSans"
msgstr ""
"Noto Serif/Noto Sans: антиква тақырыбы мен гротескте терілген негізгі мәтіні "
"бар стиль."

msgid "plugins.themes.custom.option.typography.notoSans_notoSerif"
msgstr ""
"Noto Serif/Noto Sans: антиква тақырыбы мен гротескте терілген негізгі мәтіні "
"бар стиль."

msgid "plugins.themes.custom.option.typography.lato"
msgstr "Lato: жаңа стильдегі қаріп."

msgid "plugins.themes.custom.option.typography.lora"
msgstr "Lora: экраннан оқуға ыңғайлы кең қаріп."

msgid "plugins.themes.custom.option.typography.lora_openSans"
msgstr ""
